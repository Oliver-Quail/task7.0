<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    app:startDestination="@id/home_fragment"
    android:id="@+id/app_navigation">
    <fragment
        android:id="@+id/home_fragment"
        android:name="com.example.task70.Fragments.HomeFragment"
        tools:layout="@layout/fragment_home">

    </fragment>

    <fragment
        android:id="@+id/create_advert_fragment"
        android:name="com.example.task70.Fragments.CreateAdvertFragment"
        tools:layout="@layout/fragment_create_advert">
    </fragment>

    <fragment
        android:id="@+id/lost_found_fragment"
        android:name="com.example.task70.Fragments.LostAndFoundFragment"
        tools:layout="@layout/fragment_lost_and_found">
        <action android:id="@+id/view_item"
            app:destination="@id/view_item_fragment">

        </action>
    </fragment>

    <fragment
        android:id="@+id/view_item_fragment"
        android:name="com.example.task70.Fragments.ViewItemFragment"
        tools:layout="@layout/fragment_view_item">

    </fragment>
</navigation>